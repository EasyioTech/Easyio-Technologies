{
  "permissions": {
    "allow": [
      "Bash",
      "Read(**)",
      "Write(**)",
      "Edit(**)",
      "Git"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Write(/etc/**)",
      "Write(/bin/**)",
      "Write(/usr/**)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "skipDangerousModePermissionPrompt": true
}